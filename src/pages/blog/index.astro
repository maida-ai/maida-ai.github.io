    <div class="max-w-6xl mx-auto px-6">
      <div
        class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6"
      >
        More posts
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {
          stubs.map((post, i) => (
            <div
              class="reveal group rounded-xl border border-border bg-surface p-6 flex flex-col"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class="flex flex-wrap gap-1.5 mb-4">
                {post.tags.map((tag) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-mono bg-green/10 text-green border border-green/20">
                    {tag}
                  </span>
                ))}
              </div>

              <h3 class="text-base font-bold text-text-primary mb-3 leading-snug flex-1">
                {post.title}
              </h3>
              <p class="text-text-muted text-sm leading-relaxed mb-5">
                {post.excerpt}
              </p>

              <div class="flex items-center justify-between mt-auto pt-4 border-t border-border">
                <div class="flex items-center gap-2 text-xs text-text-muted font-mono">
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-surface border border-border text-text-muted">
                    Coming soon
                  </span>
                  <span>{post.readingTime}</span>
                </div>
                <span class="text-xs text-text-muted font-mono">→</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════════════════════ -->
