        <a
          href="/blog"
          class="text-sm text-text-primary transition-colors hover-underline"
          >Blog</a
        >
        <a
          href="/about"
          class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline"
          >About</a
        >
        <a
          href="/docs"
          class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline"
          >Docs</a
        >
      </div>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/agentdbg/agentdbg"
          class="hidden sm:flex items-center gap-1.5 text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path
