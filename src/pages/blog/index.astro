       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div
      class="absolute inset-0 bg-grid-pattern bg-grid opacity-100 pointer-events-none"
    >
    </div>
    <div class="absolute inset-0 bg-green-radial pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-6">
      <div class="reveal">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green/20 bg-green/5 text-green text-xs font-mono mb-6"
        >
          Blog
        </div>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-[1.05] mb-5"
        >
          Patterns in AI agent<br />
          <span class="text-gradient">engineering.</span>
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
          From the Refine AI team — practical writing on CI gates, behavioral
          testing, and shipping reliable AI agents.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FEATURED POST
  ═══════════════════════════════════════════════════════════════ -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div
        class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6"
      >
        Featured post
      </div>

      <a
        href={`/blog/${featured.slug}`}
        class="reveal group block rounded-xl border border-border bg-surface p-8 hover:border-green/30 hover:shadow-green-sm hover:-translate-y-0.5 transition-all duration-300"
      >
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {
            featured.tags.map((tag) => (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-mono bg-green/10 text-green border border-green/20">
                {tag}
              </span>
            ))
          }
        </div>

        <div class="grid md:grid-cols-[1fr_auto] gap-6 items-end">
          <div>
            <h2
              class="text-2xl sm:text-3xl font-bold text-text-primary group-hover:text-green transition-colors mb-4 leading-snug"
            >
              {featured.title}
            </h2>
            <p class="text-text-secondary leading-relaxed max-w-2xl">
              {featured.excerpt}
            </p>
          </div>
          <div class="flex flex-col items-start md:items-end gap-3 shrink-0">
            <div
              class="flex items-center gap-3 text-xs text-text-muted font-mono"
            >
              <span>{featured.date}</span>
              <span class="text-border">·</span>
              <span>{featured.readingTime}</span>
            </div>
            <span
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-green group-hover:gap-3 transition-all"
            >
              Read
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       POST GRID
  ═══════════════════════════════════════════════════════════════ -->
