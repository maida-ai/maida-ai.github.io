            </a>
          </div>
        </div>

        <!-- Product -->
        <div>
          <div class="font-semibold text-sm mb-4 text-text-primary">
            Product
          </div>
          <ul class="space-y-2.5">
            {
              [
                { label: "How it works", href: "/#how-it-works" },
                { label: "Behavioral checks", href: "/#checks" },
                { label: "Pricing", href: "/pricing" },
