---
import Layout from "../../layouts/Layout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<Layout
  title="Respan Alternative — Refine AI"
  description="Respan debugs agent failures after they happen. Refine AI prevents them from shipping in the first place. See how they compare."
>
  <!-- NAV -->
  <header id="nav" class="fixed top-0 left-0 right-0 z-50 border-b border-border/60 backdrop-blur-xl bg-bg/80">
    <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-7 h-7 rounded bg-green/10 border border-green/30 flex items-center justify-center group-hover:bg-green/20 transition-colors">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 2L3 4.5v4c0 2.5 2.2 4.8 5 5.5 2.8-.7 5-3 5-5.5v-4L8 2z" stroke="#00ff88" stroke-width="1.2" fill="none" stroke-linejoin="round"></path>
            <polyline points="5.5 8 7.2 9.8 10.5 6.5" stroke="#00ff88" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></polyline>
          </svg>
        </div>
        <span class="font-mono font-bold text-sm text-text-primary tracking-tight">Refine AI</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/#how-it-works" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">How it works</a>
        <a href="/#checks" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">Checks</a>
        <a href="/pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">Pricing</a>
        <a href="/blog" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">Blog</a>
        <a href="/about" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">About</a>
        <a href="/docs" class="text-sm text-text-secondary hover:text-text-primary transition-colors hover-underline">Docs</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="https://github.com/agentdbg/agentdbg" class="hidden sm:flex items-center gap-1.5 text-sm text-text-secondary hover:text-text-primary transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"></path></svg>
          GitHub
        </a>
        <a href="https://zcal.co/refineai/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-border-light text-text-secondary text-sm font-semibold hover:text-text-primary hover:border-green/30 transition-colors">
          <span class="sm:hidden">Demo</span>
          <span class="hidden sm:inline">Book a demo</span>
        </a>
        <a href="/#get-started" class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-md bg-green text-bg text-sm font-semibold hover:bg-green-dim transition-colors">Get started free</a>
      </div>
    </nav>
  </header>

  <main class="pt-14">
    <section class="relative pt-20 pb-16 overflow-hidden">
      <div class="absolute inset-0 bg-green-radial pointer-events-none"></div>
      <div class="relative max-w-6xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green/20 bg-green/5 text-green text-xs font-mono mb-8">Respan Alternative</div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6">
          Stop debugging regressions.<br /><span class="text-gradient">Start preventing them.</span>
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto mb-10 leading-relaxed">Respan is a powerful debugger for understanding agent failures after they occur. Refine AI is the gate that prevents those failures from reaching production in the first place. These are complementary tools — but if you're choosing one for CI, the choice is clear.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#get-started" class="btn-glow inline-flex items-center gap-2 px-7 py-3.5 rounded-lg bg-green text-bg text-base font-bold hover:bg-green-dim transition-all">Get started free</a>
          <a href="/docs" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg border border-border-light text-text-secondary hover:text-text-primary hover:border-green/30 transition-all text-base font-medium">View docs →</a>
        </div>
      </div>
    </section>

    <section class="py-20 reveal">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-black tracking-tight mb-8 text-center">At a glance</h2>
        <div class="bg-surface border border-border rounded-xl overflow-hidden">
          <div class="grid grid-cols-3 bg-[#0d0d0d] border-b border-border px-6 py-3">
            <span class="text-text-muted text-sm font-mono"></span>
            <span class="text-text-primary text-sm font-semibold text-center">Respan</span>
            <span class="text-green text-sm font-semibold text-center">Refine AI</span>
          </div>
          {[
            ["CI/CD gate (fails PR)", "✗ No", "✓ Yes"],
            ["Primary use case", "Debugging after failure", "Preventing failure"],
            ["Baseline comparison", "✗ No", "✓ HEAD vs main"],
            ["Run replay", "✓ Excellent", "✗ Not included"],
            ["Auto-enforcement", "✗ Manual", "✓ Automatic"],
            ["Agent support", "✓ Yes", "✓ Yes"],
            ["Setup time", "Minutes", "5 minutes"],
            ["Framework-agnostic", "✓ Yes", "✓ Yes"],
          ].map(([dim, respan, refine], i) => (
            <div class={`grid grid-cols-3 px-6 py-3.5 ${i % 2 === 0 ? "" : "bg-[#0d0d0d]/40"}`}>
              <span class="text-text-secondary text-sm">{dim}</span>
              <span class={`text-sm text-center ${respan.startsWith("✗") ? "text-text-muted" : "text-text-secondary"}`}>{respan}</span>
              <span class={`text-sm text-center font-medium ${refine.startsWith("✓") ? "text-green" : "text-text-primary"}`}>{refine}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 reveal">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-black tracking-tight mb-3 text-center">Debugger vs. gatekeeper</h2>
        <p class="text-text-secondary text-center mb-10 max-w-xl mx-auto">Respan and Refine AI answer different questions. Here's what you're missing if you only have one.</p>
        <div class="grid md:grid-cols-3 gap-5">
          <div class="bg-surface border border-border rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-danger/10 border border-danger/20 flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ff4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <h3 class="font-bold text-text-primary mb-2">Debugger vs. gatekeeper — different jobs</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Respan is excellent for understanding why an agent failed. But it doesn't prevent the regression from reaching production. By the time you're debugging in Respan, the bad PR has already merged. Refine AI is the check that catches it before merge — before users are affected.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-warning/10 border border-warning/20 flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffaa00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 class="font-bold text-text-primary mb-2">No baseline delta comparison</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Respan records individual runs in isolation. It doesn't compare this PR's behavior against the main branch baseline. Refine AI's core feature is exactly this delta: "step_count went from 6 to 22 in this PR — FAIL." Without a baseline, you can't detect regressions automatically.</p>
          </div>
          <div class="bg-surface border border-border rounded-xl p-6">
            <div class="w-10 h-10 rounded-lg bg-info/10 border border-info/20 flex items-center justify-center mb-4">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4488ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
            </div>
            <h3 class="font-bold text-text-primary mb-2">No way to fail a PR</h3>
            <p class="text-text-secondary text-sm leading-relaxed">There's no Respan configuration that fails a GitHub check. It's a debugging tool, not an enforcement tool. Refine AI is designed from the ground up as a CI gate — the assertion is the artifact, the PR status is the output.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 border-t border-border reveal">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-black tracking-tight mb-10 text-center">How Refine AI is different</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { title: "Prevents, not just debugs", desc: "Catch regressions at the PR, before they ship. Respan helps you understand failures; Refine AI stops them." },
            { title: "Baseline delta on every PR", desc: "Compare HEAD vs main. See step_count, tool_calls, loop_risk delta for every code change." },
            { title: "Automatic PR blocking", desc: "No action required from the team. The check fails, the PR is blocked, the engineer is notified." },
            { title: "CI-native design", desc: "Built around the GitHub PR workflow. The output is a check status that gates the merge." },
          ].map((f) => (
            <div class="bg-surface border border-green/10 rounded-xl p-6">
              <div class="w-2 h-2 rounded-full bg-green mb-4"></div>
              <h3 class="font-bold text-text-primary mb-2">{f.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 reveal">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-black tracking-tight mb-10 text-center">Who each tool is built for</h2>
        <div class="grid md:grid-cols-2 gap-5">
          <div class="bg-surface border border-border rounded-xl p-6">
            <h3 class="font-mono font-bold text-text-secondary mb-4">Use Respan if…</h3>
            <ul class="space-y-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-text-muted mt-0.5">→</span>You need powerful post-failure debugging and run replay</li>
              <li class="flex gap-2"><span class="text-text-muted mt-0.5">→</span>You want to understand agent decision-making visually</li>
              <li class="flex gap-2"><span class="text-text-muted mt-0.5">→</span>Time-travel debugging is important to your incident workflow</li>
            </ul>
          </div>
          <div class="bg-surface border border-green/20 rounded-xl p-6">
            <h3 class="font-mono font-bold text-green mb-4">Use Refine AI if…</h3>
            <ul class="space-y-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-green mt-0.5">→</span>You want to prevent agent regressions from shipping in the first place</li>
              <li class="flex gap-2"><span class="text-green mt-0.5">→</span>You need automated PR gating with baseline comparison</li>
              <li class="flex gap-2"><span class="text-green mt-0.5">→</span>You want CI to catch behavioral changes at the commit level</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 border-t border-border reveal">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl font-black tracking-tight mb-3 text-center">Get started in 5 minutes</h2>
        <p class="text-text-secondary text-center mb-8">Add the gate. Stop debugging avoidable regressions.</p>
        <div class="bg-[#0d0d0d] border border-border rounded-xl overflow-hidden">
          <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div><div class="w-3 h-3 rounded-full bg-[#febc2e]"></div><div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            <span class="ml-2 font-mono text-xs text-text-muted">.github/workflows/agent-regression.yml</span>
          </div>
          <pre class="p-6 font-mono text-sm text-text-secondary overflow-x-auto leading-relaxed"><code><span class="text-text-muted">- name:</span> <span class="text-green">Assert agent behavior</span>
  <span class="text-text-muted">uses:</span> <span class="text-text-primary">agentdbg/agentdbg-action@v1</span>
  <span class="text-text-muted">with:</span>
    <span class="text-text-muted">baseline:</span> <span class="text-text-primary">main</span>
    <span class="text-text-muted">checks:</span> <span class="text-text-primary">step_count,tool_calls,loop_risk,cost,latency</span></code></pre>
        </div>
        <div class="flex justify-center mt-6">
          <a href="/docs" class="inline-flex items-center gap-2 text-green hover:text-green-dim transition-colors text-sm font-medium">Read the full setup guide →</a>
        </div>
      </div>
    </section>

    <section id="get-started" class="py-24 reveal">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="bg-surface border border-green/20 rounded-2xl p-12 shadow-green-lg">
          <h2 class="text-3xl font-black tracking-tight mb-4">Gate the PR. Skip the debug session.</h2>
          <p class="text-text-secondary text-lg mb-8">Catch agent regressions before they ship. The best debug session is the one you never have to do.</p>
          <a href="https://github.com/agentdbg/agentdbg" class="btn-glow inline-flex items-center gap-2 px-7 py-3.5 rounded-lg bg-green text-bg text-base font-bold hover:bg-green-dim transition-all">Add to GitHub Actions</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
